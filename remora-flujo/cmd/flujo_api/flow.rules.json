{
  "version": 1,
  "description": "Reglas de composición",
  "rules": [
    {
      "id": "alfa_takes_over_after_2_echo_answers",
      "description": "",
      "when": {
        "frameworks_active_all": [
          "echo",
          "alfa"
        ],
        "user_answer_count_min": 2,
        "user_answer_count_max": 2
      },
      "then": {
        "prepend_speaker": "alfa"
      }
    },
    {
      "id": "image_resource_routes_to_alfa",
      "description": "",
      "when": {
        "frameworks_active_any": [
          "alfa"
        ],
        "user_message_has_resource_type": "image"
      },
      "then": {
        "prepend_speaker": "alfa",
        "preprocess": "vision"
      }
    }
  ]
}
