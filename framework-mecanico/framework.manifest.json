{
  "name": "mecanico",
  "version": "0.1.0",
  "description": "Agente reparador. Toma findings producidos por framework-auditor y propone (sin ejecutar) un plan de remediación. Aplica el fix solo cuando el usuario lo confirma. Opera sobre dataset.working.json del auditor y deja audit-trail en applied.jsonl.",
  "build": {
    "command": "go",
    "args": ["build", "-buildvcs=false", "-o", "frameworkmecanico", "./cmd/frameworkmecanico"]
  },
  "binary": {
    "command": "./frameworkmecanico",
    "args_prefix": []
  },
  "cwd": "framework-mecanico",
  "execution_mode": "sync_chain",
  "requires_infra": [],
  "inputs": [
    {
      "name": "findings",
      "format": "auditor.findings.v1",
      "path": "../framework-auditor/data/findings.json",
      "required": true,
      "description": "Salida del último scan del auditor"
    },
    {
      "name": "dataset",
      "format": "external.api.dump.v1",
      "path": "../framework-auditor/data/dataset.working.json",
      "required": true,
      "description": "Dataset mutable que el mecánico modifica al aplicar fixes"
    }
  ],
  "outputs": [
    {
      "name": "proposals",
      "format": "mecanico.proposals.v1",
      "path": "data/proposals.json",
      "description": "Propuestas de fix pendientes de aprobación"
    },
    {
      "name": "applied_log",
      "format": "mecanico.applied.v1",
      "path": "data/applied.jsonl",
      "description": "Audit-trail de fixes aplicados"
    }
  ],
  "commands": {
    "propose": {
      "description": "Genera propuesta de fix para un finding (no ejecuta)",
      "args": ["propose", "--finding-id", "{params.finding_id}"],
      "params": ["finding_id"]
    },
    "propose-all-auto": {
      "description": "Genera propuestas para todos los findings auto-corregibles",
      "args": ["propose-all-auto"],
      "params": []
    },
    "list-proposals": {
      "description": "Lista propuestas pendientes",
      "args": ["list-proposals"],
      "params": []
    },
    "apply": {
      "description": "Aplica un fix propuesto al dataset.working.json",
      "args": ["apply", "--proposal-id", "{params.proposal_id}"],
      "params": ["proposal_id"]
    },
    "apply-all": {
      "description": "Aplica TODAS las propuestas pendientes (usar con precaución)",
      "args": ["apply-all"],
      "params": []
    },
    "reset": {
      "description": "Limpia propuestas y log de aplicados",
      "args": ["reset"],
      "params": []
    },
    "next-question": {
      "description": "Próxima pregunta/mensaje al user",
      "args": ["next-question"],
      "params": []
    },
    "ingest-answer": {
      "description": "Recibe respuesta del user y avanza el flujo",
      "args": ["ingest-answer", "--question-id", "{params.question_id}", "--answer", "{params.answer}"],
      "params": ["question_id", "answer"]
    }
  },
  "asks_human": {
    "via": "user",
    "path": "next-question",
    "description": "Mecánico pregunta al user antes de aplicar cualquier fix"
  },
  "user_input": {
    "supported": true,
    "ask_via": "",
    "modes": ["short_answer"],
    "next_question_cmd": "next-question",
    "ingest_answer_cmd": "ingest-answer"
  },
  "model": {
    "provider": "minimax",
    "name": "MiniMax-M2.7",
    "env_key": "MINIMAX_API_KEY",
    "capabilities": ["text"]
  },
  "capabilities_semantic": {
    "tags": ["fix", "remediation", "erp", "data-quality"],
    "intent_examples": [
      "arreglá los errores",
      "corregí los datos faltantes",
      "aplicá los fixes auto-corregibles"
    ],
    "produces": ["fixes_applied:dataset"],
    "requires": ["findings:erp_audit"]
  }
}
