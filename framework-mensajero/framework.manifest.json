{
  "name": "mensajero",
  "version": "0.1.0",
  "description": "Envía mensajes salientes por cualquier canal (email/sms/whatsapp). Es agnóstico al negocio: recibe un draft (subject+body+to+channel) y credenciales canónicas del vault, y ejecuta el envío. No genera contenido (eso es trabajo de redactor/mecánico) ni gestiona credenciales (eso es trabajo de hosting u otros provisioners).",
  "build": {
    "command": "go",
    "args": [
      "build",
      "-buildvcs=false",
      "-o",
      "frameworkmensajero",
      "./cmd/frameworkmensajero"
    ]
  },
  "binary": {
    "command": "./frameworkmensajero",
    "args_prefix": []
  },
  "cwd": "framework-mensajero",
  "execution_mode": "async_trigger",
  "requires_infra": [],
  "model": {
    "provider": "groq",
    "name": "meta-llama/llama-4-scout-17b-16e-instruct",
    "env_key": "GROQ_API_KEY",
    "capabilities": [
      "text",
      "conversation"
    ]
  },
  "commands": {
    "next-question": {
      "description": "Devuelve confirmación de envíos pendientes (idle por defecto)",
      "args": [
        "next-question",
        "--conv-id",
        "{params.conv_id}"
      ],
      "params": [
        "conv_id"
      ],
      "defaults": {
        "conv_id": ""
      }
    },
    "ingest-answer": {
      "description": "No-op por compatibilidad con el contrato conversacional",
      "args": [
        "ingest-answer",
        "--question-id",
        "{params.question_id}",
        "--answer",
        "{params.answer}",
        "--conv-id",
        "{params.conv_id}"
      ],
      "params": [
        "question_id",
        "answer",
        "conv_id"
      ],
      "defaults": {
        "conv_id": ""
      }
    },
    "can-send": {
      "description": "Verifica si el consumer puede leer y usar la capability del canal en el mismo scope/runtime que usará send. Imprime JSON {available, present, readable, complete, missing_capability?, provider_hint?}",
      "args": [
        "can-send",
        "--channel",
        "{params.channel}",
        "--conv-id",
        "{params.conv_id}"
      ],
      "params": [
        "channel",
        "conv_id"
      ],
      "defaults": {
        "conv_id": ""
      }
    },
    "send": {
      "description": "Envía un mensaje. Lee credenciales.{channel} del vault. Imprime JSON {success, message_id?, error?}.",
      "args": [
        "send",
        "--channel",
        "{params.channel}",
        "--to",
        "{params.to}",
        "--subject",
        "{params.subject}",
        "--body-b64",
        "{params.body_b64}",
        "--conv-id",
        "{params.conv_id}"
      ],
      "params": [
        "channel",
        "to",
        "subject",
        "body_b64",
        "conv_id"
      ],
      "defaults": {
        "conv_id": "",
        "subject": "",
        "to": ""
      }
    }
  },
  "user_input": {
    "supported": false
  },
  "state": {
    "dir": "temp",
    "files": [
      "state_*.json",
      "sent_*.jsonl"
    ]
  },
  "semantic_rules": {
    "use_when": ["enviar email", "enviar mensaje", "notificar", "reporte por correo", "smtp", "comunicar resultado", "mandar", "alertar", "enviar reporte"],
    "position": "output",
    "not_for": ["análisis de datos", "priorización", "corregir datos", "auditoría"],
    "covers_integrations": ["smtp", "email"]
  },
  "capabilities_semantic": {
    "tags": [
      "messaging",
      "send",
      "smtp",
      "email",
      "outbound"
    ],
    "intent_examples": [
      "enviar este email",
      "mandar el mensaje",
      "send the draft"
    ],
    "produces": [
      "message.sent",
      "action.email_send"
    ],
    "requires": [
      "credentials.smtp"
    ]
  },
  "capabilities": [
    {
      "id": "message.can_send",
      "description": "Verifica si el canal de envío tiene credenciales disponibles para la conversación/perfil.",
      "command": "can-send",
      "inputs": [
        "message.channel.v1",
        "session.context.v1"
      ],
      "outputs": [
        "message.send_readiness.v1"
      ],
      "requires": [
        "session.context.v1"
      ],
      "produces": [
        "message.send_readiness.v1"
      ],
      "execution": "vault_capability_check",
      "policies": [
        "safe_for_runtime",
        "no_external_side_effect",
        "vault_scoped"
      ]
    },
    {
      "id": "message.send",
      "description": "Envía un mensaje saliente ya redactado por el canal solicitado usando credenciales canónicas del vault.",
      "command": "send",
      "inputs": [
        "message.draft.v1",
        "credentials.smtp",
        "contact.destination.v1",
        "business.context.v1"
      ],
      "outputs": [
        "message.sent.v1"
      ],
      "requires": [
        "message.draft.v1",
        "credentials.smtp",
        "contact.destination.v1"
      ],
      "produces": [
        "message.sent.v1",
        "message.sent",
        "action.email_send"
      ],
      "execution": "external_channel_send",
      "policies": [
        "external_side_effect",
        "approval_required",
        "trace_required",
        "cycle_terminal",
        "vault_scoped",
        "audit_log_required"
      ]
    }
  ],
  "interaction_mode": "conversational"
}
