{
  "description": "Reglas de orquestación para el perfil Cobranza-Chile. Define quién habla cuándo en el flujo de cobranza.",
  "version": "1.0.0",
  "rules": [
    {
      "id": "foco_primero_pregunta_inicial",
      "description": "Si es la primera pregunta del día y el usuario pregunta 'qué hago hoy', 'prioridades', o 'a quién llamo', Foco habla primero",
      "conditions": {
        "user_answer_count_max": 1,
        "message_matches_any": [
          "qué hago hoy",
          "prioridades",
          "a quién llamo",
          "a quien llamo",
          "con quién empiezo",
          "con quien empiezo",
          "cuáles son las prioridades",
          "cuales son las prioridades",
          "top deudores"
        ]
      },
      "actions": {
        "prepend_speaker": "foco"
      }
    },
    {
      "id": "sabio_contexto_deudor",
      "description": "Si el usuario menciona un deudor específico (nombre o código), Sabio debe responder con el 360°",
      "conditions": {
        "frameworks_active_any": ["foco", "sabio"],
        "message_has_entity": "deudor"
      },
      "actions": {
        "prepend_speaker": "sabio"
      }
    },
    {
      "id": "mecanico_genera_accion",
      "description": "Si el usuario pide enviar mail, generar carta, o cualquier acción sobre un deudor, Mecánico propone el borrador",
      "conditions": {
        "frameworks_active_any": ["sabio", "mecanico"],
        "message_matches_any": [
          "mandar mail",
          "mandar email",
          "enviar correo",
          "generar carta",
          "carta de requerimiento",
          "recordatorio",
          "requerimiento formal",
          "escribir a",
          "enviar a"
        ]
      },
      "actions": {
        "prepend_speaker": "mecanico"
      }
    },
    {
      "id": "bravo_verifica_flujo_legal",
      "description": "Si detectamos mora >= 60 días, Bravo se prepende automáticamente para verificar cumplimiento legal antes de DICOM",
      "conditions": {
        "frameworks_active_any": ["sabio", "bravo"],
        "detected_mora_days_min": 60,
        "user_answer_count_min": 2
      },
      "actions": {
        "prepend_speaker": "bravo",
        "note": "Verificar si ya existe carta de requerimiento previa según Art. 37"
      }
    },
    {
      "id": "gmail_ejecuta",
      "description": "Si Mecánico generó una propuesta y el usuario confirma, Gmail abre el borrador",
      "conditions": {
        "frameworks_active_any": ["mecanico", "gmail"],
        "message_matches_any": [
          "confirmar",
          "ok",
          "dale",
          "enviar",
          "mandar",
          "sí",
          "si"
        ],
        "previous_framework_was": "mecanico"
      },
      "actions": {
        "prepend_speaker": "gmail"
      }
    }
  ],
  "entity_detection": {
    "deudor": {
      "patterns": [
        "deudor",
        "cliente",
        "empresa",
        "señor",
        "señora",
        "sr.",
        "sra.",
        "banco",
        "constructora",
        "spa",
        "limitada"
      ],
      "tables": ["clients", "debtors", "companies"]
    }
  }
}
