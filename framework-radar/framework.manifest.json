{
  "name": "radar",
  "version": "0.1.0",
  "description": "Radar analítico data-aware. Calcula scoring, prioridad y esquema de análisis desde datos declarados del negocio sin ejecutar ni sugerir acciones operativas.",
  "build": {
    "command": "go",
    "args": [
      "build",
      "-o",
      "frameworkradar",
      "./cmd/frameworkradar"
    ]
  },
  "binary": {
    "command": "./frameworkradar",
    "args_prefix": []
  },
  "cwd": "framework-radar",
  "execution_mode": "async_trigger",
  "requires_infra": [],
  "commands": {
    "prioritize": {
      "description": "Calcula entidades de cobranza priorizadas desde dataset.raw.v1 mediado por Sabio y semantic pack del negocio.",
      "args": [
        "prioritize",
        "--business-id",
        "{params.business_id}",
        "--semantic-pack",
        "{params.semantic_pack}",
        "--dataset-artifact",
        "{params.dataset_artifact}",
        "--context-b64",
        "{params.context_b64}"
      ],
      "params": [
        "business_id",
        "semantic_pack",
        "dataset_artifact",
        "context_b64"
      ],
      "defaults": {
        "business_id": "",
        "semantic_pack": "",
        "dataset_artifact": "",
        "context_b64": ""
      }
    },
    "configure-analysis": {
      "description": "Diseña y persiste el esquema/configuración de análisis desde el semantic pack del negocio.",
      "args": [
        "configure-analysis",
        "--business-id",
        "{params.business_id}",
        "--semantic-pack",
        "{params.semantic_pack}",
        "--context-b64",
        "{params.context_b64}"
      ],
      "params": [
        "business_id",
        "semantic_pack",
        "context_b64"
      ],
      "defaults": {
        "business_id": "",
        "semantic_pack": "",
        "context_b64": ""
      }
    },
    "deep-dive": {
      "description": "Analiza en profundidad el caso priorizado y formula el plan analítico antes de cualquier acción operativa.",
      "args": [
        "deep-dive",
        "--business-id",
        "{params.business_id}",
        "--entity-ref",
        "{params.entity_ref}",
        "--entity-type",
        "{params.entity_type}",
        "--semantic-pack",
        "{params.semantic_pack}",
        "--priority-list-path",
        "{params.priority_list_path}",
        "--priority-list-json",
        "{params.priority_list_json}",
        "--strategy-path",
        "{params.strategy_path}",
        "--strategy-json",
        "{params.strategy_json}",
        "--context-b64",
        "{params.context_b64}"
      ],
      "params": [
        "business_id",
        "entity_ref",
        "entity_type",
        "semantic_pack",
        "priority_list_path",
        "priority_list_json",
        "strategy_path",
        "strategy_json",
        "context_b64"
      ],
      "defaults": {
        "business_id": "",
        "entity_ref": "",
        "entity_type": "customer",
        "semantic_pack": "",
        "priority_list_path": "",
        "priority_list_json": "",
        "strategy_path": "",
        "strategy_json": "",
        "context_b64": ""
      }
    },
    "analyze-followup": {
      "description": "Recibe un follow-up del usuario dentro de la sesión analítica activa y responde con análisis adicional, delegando a Sabio/Auditor si hace falta.",
      "args": [
        "analyze-followup",
        "--business-id",
        "{params.business_id}",
        "--input",
        "{params.input}",
        "--entity-ref",
        "{params.entity_ref}",
        "--entity-type",
        "{params.entity_type}",
        "--semantic-pack",
        "{params.semantic_pack}",
        "--previous-analysis-path",
        "{params.previous_analysis_path}",
        "--previous-analysis-json",
        "{params.previous_analysis_json}",
        "--delegation-results-path",
        "{params.delegation_results_path}",
        "--delegation-results-json",
        "{params.delegation_results_json}",
        "--priority-list-path",
        "{params.priority_list_path}",
        "--priority-list-json",
        "{params.priority_list_json}",
        "--turn-count",
        "{params.turn_count}",
        "--llm-followup-path",
        "{params.llm_followup_path}",
        "--llm-followup-json",
        "{params.llm_followup_json}",
        "--context-b64",
        "{params.context_b64}"
      ],
      "params": [
        "business_id",
        "input",
        "entity_ref",
        "entity_type",
        "semantic_pack",
        "previous_analysis_path",
        "previous_analysis_json",
        "delegation_results_path",
        "delegation_results_json",
        "priority_list_path",
        "priority_list_json",
        "turn_count",
        "llm_followup_path",
        "llm_followup_json",
        "context_b64"
      ],
      "defaults": {
        "business_id": "",
        "input": "",
        "entity_ref": "",
        "entity_type": "customer",
        "semantic_pack": "",
        "previous_analysis_path": "",
        "previous_analysis_json": "",
        "delegation_results_path": "",
        "delegation_results_json": "",
        "priority_list_path": "",
        "priority_list_json": "",
        "turn_count": "0",
        "llm_followup_path": "",
        "llm_followup_json": "",
        "context_b64": ""
      }
    }
  },
  "capabilities_semantic": {
    "tags": [
      "radar",
      "collections",
      "priority-scoring",
      "readonly-data"
    ],
    "intent_examples": [
      "a quién cobrar primero",
      "prioriza cartera de cobranza",
      "calcula lista de deudores",
      "radar de clientes cobrables"
    ],
    "produces": [
      "collection.priority_list.v1",
      "collection.priority_item.v1",
      "entity.ref.v1",
      "risk.score.v1",
      "strategy.recommendation.v1",
      "data.gaps.v1",
      "data.request.v1",
      "analysis.schema.v1",
      "analysis.plan.v1",
      "analysis.proposal.v1"
    ],
    "requires": [
      "dataset.raw.v1",
      "business.semantic_pack.v1"
    ]
  },
  "capabilities": [
    {
      "id": "analysis.deep_dive",
      "description": "Toma control del tramo analítico del caso seleccionado y explicita la evidencia/delegación necesaria antes de actuar.",
      "command": "deep-dive",
      "inputs": [
        "collection.priority_list.v1",
        "entity.ref.v1",
        "strategy.recommendation.v1",
        "business.semantic_pack.v1"
      ],
      "outputs": [
        "analysis.case_review.v1",
        "answer.grounded.v1"
      ],
      "requires": [
        "collection.priority_list.v1",
        "entity.ref.v1"
      ],
      "produces": [
        "analysis.case_review.v1",
        "answer.grounded.v1"
      ],
      "execution": "selected_case_analytical_takeover",
      "policies": [
        "readonly_dataset",
        "trace_required",
        "business_context_required",
        "owner_takeover"
      ],
      "session": {
        "conversational": true,
        "followup_command": "analyze-followup",
        "continue_signals": [
          "profundiza", "explica", "por qué", "compara", "detalle",
          "riesgo", "mora", "evidencia", "más", "amplía",
          "qué pasaría", "alternativa", "y si"
        ],
        "operational_signals": [
          "avanza", "actuar", "con eso basta",
          "redacta", "manda", "envía", "usa lo que tenemos",
          "gestionar", "cobrar", "contactar"
        ],
        "exit_signals": [
          "siguiente caso", "siguiente cliente", "skip", "saltar",
          "posponer", "déjalo", "dejalo", "otro caso", "no analizar"
        ],
        "allowed_delegates": [
          "data.entity_360",
          "data.query.sql",
          "data.quality.audit"
        ],
        "max_turns": 10
      }
    },
    {
      "id": "analysis.configure",
      "description": "Formula una forma configurable de analizar los registros usando configuración semántica del negocio, sin acceso directo a SQLite.",
      "command": "configure-analysis",
      "inputs": [
        "business.context.v1",
        "business.semantic_pack.v1"
      ],
      "outputs": [
        "analysis.schema.v1",
        "analysis.plan.v1",
        "analysis.proposal.v1"
      ],
      "requires": [
        "business.semantic_pack.v1"
      ],
      "produces": [
        "analysis.schema.v1",
        "analysis.plan.v1",
        "analysis.proposal.v1"
      ],
      "execution": "analysis_schema_generation_from_semantic_pack",
      "policies": [
        "trace_required",
        "install_once",
        "human_acceptance_before_continue",
        "human_acceptance_before_prioritization"
      ]
    },
    {
      "id": "collection.priority_list",
      "description": "Calcula entidades de cobranza priorizadas desde dataset.raw.v1 mediado por Sabio.",
      "command": "prioritize",
      "inputs": [
        "business.context.v1",
        "dataset.raw.v1",
        "business.semantic_pack.v1"
      ],
      "outputs": [
        "collection.priority_list.v1",
        "collection.priority_item.v1",
        "entity.ref.v1",
        "risk.score.v1",
        "strategy.recommendation.v1",
        "data.gaps.v1",
        "data.request.v1",
        "analysis.schema.v1",
        "analysis.plan.v1"
      ],
      "requires": [
        "dataset.raw.v1",
        "business.semantic_pack.v1"
      ],
      "produces": [
        "collection.priority_list.v1",
        "collection.priority_item.v1",
        "entity.ref.v1",
        "risk.score.v1",
        "strategy.recommendation.v1",
        "data.gaps.v1",
        "data.request.v1",
        "analysis.schema.v1",
        "analysis.plan.v1"
      ],
      "execution": "deterministic_business_priority_scoring",
      "policies": [
        "readonly_dataset",
        "trace_required",
        "business_context_required",
        "no_silent_fallback"
      ]
    }
  ]
}
