# =============================================================================
# Remora Go - Plantilla de variables de entorno
# =============================================================================
# Copialo a .env (que esta en .gitignore) y completa con tus valores:
#   cp .env.example .env
#
# En produccion (Cloud Run) estas mismas variables se setean via Secret Manager
# o como env vars del servicio. NUNCA commitear el .env real.
# =============================================================================

# --- LLM providers (al menos uno requerido) ---------------------------------
# Groq (rapido, recomendado por defecto)
GROQ_API_KEY=
REMORA_GROQ_MODEL=llama-3.3-70b-versatile

# MiniMax (multimodal, fallback)
MINIMAX_API_KEY=
REMORA_MINIMAX_MODEL=MiniMax-M2.7

# Provider explicito (groq | minimax). Si no se setea, se infiere del primero
# que tenga API key.
REMORA_LLM_PROVIDER=groq

# --- Vault / credenciales encriptadas (REQUERIDO si usas hosting/cpanel) ----
# Clave maestra AES-256: 32 bytes en hex (64 chars) o base64 (44 chars).
# Generar local con: cd framework-hosting && go run ./cmd/frameworkhosting genkey
REMORA_VAULT_KEY=
HOSTING_VAULT_KEY=

# Directorios opcionales del vault
REMORA_VAULT_DIR=channel/vault_data
REMORA_VAULT_BIN=channel/bin/vault

# --- Channel (orquestador JSON-RPC) -----------------------------------------
# API keys validas para el channel (csv). En dev podes usar un valor cualquiera.
CHANNEL_API_KEYS=test-key-001
CHANNEL_BASE_DIR=/Users/alcless_a1234_cursor/remora-go
CHANNEL_EXEC_TIMEOUT=120s

# --- Perfil del cliente activo ----------------------------------------------
# Selecciona la carpeta profiles/<perfil>/ que se carga.
REMORA_PROFILE=generic

# --- Modo desarrollo --------------------------------------------------------
# En true, el backend reescribe `to` de emails al recipient de test y prefija
# el subject con "[DEV -> original: ...]". En prod se infiere por K_SERVICE.
REMORA_DEV_MODE=true
TEST_EMAIL_RECIPIENT=tom3bs@gmail.com

# --- SMTP (fallback al vault para mensajero) --------------------------------
SMTP_USER=
SMTP_PASS=

# --- Display ----------------------------------------------------------------
ESTUDIO_NOMBRE=Estudio Juridico Remora
COBRADOR_NOMBRE=Departamento de Cobranza

# --- Paladin (tracing) ------------------------------------------------------
PALADIN_PORT=8099
PALADIN_SERVER_URL=http://localhost:8099

# --- Bases de datos opcionales ----------------------------------------------
# Override de paths a SQLite. Si no se setean, se usan defaults por perfil.
FOCO_DB=
TASKS_DB_PATH=
AUDITOR_STATE_REL=

# --- Cloud Run (auto-inyectadas en prod, no setear local) -------------------
# PORT=8080
# K_SERVICE=flujo-api-dev
