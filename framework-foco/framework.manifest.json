{
  "name": "foco",
  "version": "1.0.1-cobranza",
  "description": "Priorizador de deudores para cobranza-chile. Genera lista priorizada desde datos de facturación.",
  "build": {
    "command": "go",
    "args": ["build", "-o", "foco", "./cmd/foco"]
  },
  "binary": {
    "command": "./foco",
    "args_prefix": []
  },
  "cwd": "framework-foco",
  "execution_mode": "sync_chain",
  "requires_infra": [],
  "model": {
    "provider": "groq",
    "name": "meta-llama/llama-4-scout-17b-16e-instruct",
    "env_key": "GROQ_API_KEY",
    "capabilities": ["conversation", "task_prioritization", "intent_routing"]
  },
  "commands": {
    "next-question": {
      "description": "Devuelve la próxima pregunta o acción",
      "args": ["next-question", "--conv-id", "{params.conv_id}"],
      "params": ["conv_id"],
      "defaults": {"conv_id": ""}
    },
    "ingest-answer": {
      "description": "Procesa la respuesta del usuario y genera prioridades",
      "args": ["ingest-answer", "--conv-id", "{params.conv_id}", "--question-id", "{params.question_id}", "--answer", "{params.answer}", "--history", "{params.history}"],
      "params": ["conv_id", "question_id", "answer", "history"],
      "defaults": {"conv_id": "", "question_id": "", "history": ""}
    },
    "query": {
      "description": "Modo CLI directo para testing",
      "args": ["query", "--question", "{params.question}"],
      "params": ["question"]
    },
    "priorities": {
      "description": "Genera lista priorizada en formato JSON",
      "args": ["priorities"],
      "params": []
    }
  },
  "user_input": {
    "supported": true,
    "next_question_cmd": "next-question",
    "ingest_answer_cmd": "ingest-answer",
    "modes": ["query"],
    "ask_via": "cli"
  },
  "state": {
    "dir": "temp/foco",
    "files": ["state.json", "last_priority_list.json"]
  }
}
